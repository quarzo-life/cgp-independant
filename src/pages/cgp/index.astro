---
import Layout from '../../components/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CgpCard from '../../components/CgpCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getPublishedCgps } from '../../lib/cgp';

const cgps = getPublishedCgps();
---

<Layout
  title="Annuaire des CGP indépendants — CGP Indépendant"
  description="Consultez l'annuaire complet des conseillers en gestion de patrimoine indépendants référencés sur CGP Indépendant."
>
  <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Annuaire' }]} />

  <h1 class="text-3xl font-bold mb-6">Annuaire des CGP indépendants</h1>

  {cgps.length === 0 ? (
    <EmptyState message="Aucun CGP n'est référencé pour le moment." />
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {cgps.map((cgp) => <CgpCard cgp={cgp} />)}
    </div>
  )}
</Layout>
