---
const navItems = [
  { href: '/', label: 'Accueil' },
  { href: '/cgp/', label: 'Annuaire' },
  { href: '/cgp/carte/', label: 'Carte' },
  { href: '/ajouter-un-cgp/', label: 'Ajouter un CGP' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="navbar bg-base-100 border-b border-base-200">
  <div class="container mx-auto px-4">
    <div class="flex-1">
      <a href="/" class="text-lg font-semibold">CGP Indépendant</a>
    </div>
    <nav class="hidden md:flex">
      <ul class="menu menu-horizontal px-1">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="dropdown dropdown-end md:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost">
        Menu
      </div>
      <ul tabindex="0" class="menu dropdown-content bg-base-100 rounded-box z-10 mt-3 w-52 p-2 shadow">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</header>
