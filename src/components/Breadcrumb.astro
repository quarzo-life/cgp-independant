---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<div class="breadcrumbs text-sm mb-6">
  <ul>
    {items.map((item) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
      </li>
    ))}
  </ul>
</div>
