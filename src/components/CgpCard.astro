---
import type { Cgp } from '../lib/cgp';

interface Props {
  cgp: Cgp;
}

const { cgp } = Astro.props;

function normalizeForSearch(value: string): string {
  return value
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .toLowerCase();
}

const searchHaystack = normalizeForSearch(
  [
    cgp.displayName,
    cgp.firmName,
    cgp.city,
    cgp.postalCode,
    cgp.departmentCode,
    cgp.departmentName,
    cgp.region,
    cgp.oriasNumber ?? '',
    cgp.oriasCategories.join(' '),
  ].join(' '),
);
---

<article
  class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow"
  data-search={searchHaystack}
  data-department={cgp.departmentCode}
  data-city={cgp.city}
>
  <div class="card-body">
    <h3 class="card-title">{cgp.displayName}</h3>
    {cgp.firmName && <p class="text-sm text-base-content/70">{cgp.firmName}</p>}
    <p class="text-sm">
      {cgp.city}
      {cgp.departmentName && <span class="text-base-content/60"> — {cgp.departmentName} ({cgp.departmentCode})</span>}
    </p>
    <p class="text-sm text-base-content/60">{cgp.region}</p>
    {cgp.oriasNumber && (
      <p class="text-xs text-base-content/60">ORIAS n° {cgp.oriasNumber}</p>
    )}
    <div class="card-actions justify-end mt-2">
      <a href={`/cgp/${cgp.slug}/`} class="btn btn-sm btn-primary">Voir la fiche</a>
    </div>
  </div>
</article>
